import type {Vector3, FaceGeometry} from "../../types.ts";

interface RawLandmark {
    position: Vector3;
    isVisible: boolean;
}

export interface RawExtraction {
    nose: RawLandmark;
    eyes: {
        left: RawLandmark;
        right: RawLandmark;
    };
    mouth: {
        left: RawLandmark;
        right: RawLandmark;
    };
    rig: {
        leftEar: RawLandmark;
        rightEar: RawLandmark;
        leftTemple: RawLandmark;
        rightTemple: RawLandmark;
    };
    bounds: {
        top: RawLandmark;
        bottom: RawLandmark;
    };
}

export const HEAD_PROPORTIONS = {
    WIDTH: {
        EAR_TO_EAR: 1.0,
        TEMPLE_TO_TEMPLE: 0.85,
        EYE_TO_EYE: 0.45,
        MOUTH_WIDTH: 0.35
    },
    DEPTH: {
        SKULL_CENTER: 0.0,
        EYE_PLANE: -0.45,
        NOSE_TIP: -0.65,
        MOUTH_PLANE: -0.50
    },
    HEIGHT: {
        FOREHEAD_TOP: 0.6,
        EYE_LINE: 0.1,
        NOSE_BASE: -0.2,
        MOUTH_LINE: -0.4,
        CHIN_TIP: -0.7
    },
    OFFSET: {
        EAR_Y: 0.02,
    }
} as const;

export interface ParserConfig {
    physicalHeadWidth: number;
    focalLength: number;
    mirror: boolean;
}

interface WorldAnchor {
    center: Vector3,
    unitScale: number;
}

export const INDEX = {
    NOSE: 1,
    EYE_LEFT: 33,
    EYE_RIGHT: 263,
    MOUTH_LEFT: 61,
    MOUTH_RIGHT: 291,
    BROW_LEFT: 105,
    BROW_RIGHT: 334,
    EAR_LEFT: 234,
    EAR_RIGHT: 454,
    TEMPLE_LEFT: 127,
    TEMPLE_RIGHT: 356,
    TOP: 10,
    BOTTOM: 152
};

export class FaceParser {
    private config: ParserConfig;

    constructor(config: Partial<ParserConfig> = {}) {
        this.config = {
            physicalHeadWidth: config.physicalHeadWidth ?? 150,
            focalLength: config.focalLength ?? 1.0,
            mirror: config.mirror ?? false,
        };
    }

    public static parse(rawLandmarks: any[], mirror: boolean = false): FaceGeometry | null {
        const instance = new FaceParser({ mirror });
        return instance.parse(rawLandmarks);
    }

    private static extractRawData(rawLandmarks: any[]): RawExtraction {
        const createLandmark = (index: number): RawLandmark => {
            const landmark = rawLandmarks[index];
            const isVisible = !!landmark &&
                landmark.x >= 0 && landmark.x <= 1 &&
                landmark.y >= 0 && landmark.y <= 1;
            return {
                position: {
                    x: landmark?.x ?? 0,
                    y: landmark?.y ?? 0,
                    z: landmark?.z ?? 0
                },
                isVisible
            };
        };

        return {
            nose: createLandmark(INDEX.NOSE),
            eyes: {
                left: createLandmark(INDEX.EYE_LEFT),
                right: createLandmark(INDEX.EYE_RIGHT),
            },
            rig: {
                leftEar: createLandmark(INDEX.EAR_LEFT),
                rightEar: createLandmark(INDEX.EAR_RIGHT),
                leftTemple: createLandmark(INDEX.TEMPLE_LEFT),
                rightTemple: createLandmark(INDEX.TEMPLE_RIGHT),
            },
            bounds: {
                top: createLandmark(INDEX.TOP),
                bottom: createLandmark(INDEX.BOTTOM),
            }
        };
    }

    /**
     * Normalizes raw extraction to skull-centered, unit-scale coordinates.
     * After this: skull center at (0,0,0), ear-to-ear = 1.0
     */
    private normalizeToSkullCenter(extracted: RawExtraction): {
        nose: Vector3;
        leftEye: Vector3;
        rightEye: Vector3;
        leftEar: Vector3;
        rightEar: Vector3;
    } | null {
        const { leftEar: EL, rightEar: ER } = extracted.rig;
        const { left: L, right: R } = extracted.eyes;
        const nose = extracted.nose;

        if (!EL.isVisible || !ER.isVisible || !L.isVisible || !R.isVisible || !nose.isVisible) {
            return null;
        }

        const centerX = (EL.position.x + ER.position.x) / 2;
        const centerY = (EL.position.y + ER.position.y) / 2;
        const centerZ = (EL.position.z + ER.position.z) / 2;

        const earSpan = Math.abs(ER.position.x - EL.position.x);
        const unitScale = earSpan / HEAD_PROPORTIONS.WIDTH.EAR_TO_EAR;

        if (unitScale < 0.0001) return null;

        const normalize = (p: { position: Vector3 }): Vector3 => ({
            x: (p.position.x - centerX) / unitScale,
            y: (p.position.y - centerY) / unitScale,
            z: (p.position.z - centerZ) / unitScale
        });

        return {
            nose: normalize(nose),
            leftEye: normalize(L),
            rightEye: normalize(R),
            leftEar: normalize(EL),
            rightEar: normalize(ER)
        };
    }

    public calculatePositionStrategyEarToEar(extracted: RawExtraction): WorldAnchor | null {
        const { leftEar, rightEar } = extracted.rig;
        if (!leftEar.isVisible || !rightEar.isVisible) return null;

        const observedEarSpan = Math.abs(rightEar.position.x - leftEar.position.x);
        const unitScale = observedEarSpan / HEAD_PROPORTIONS.WIDTH.EAR_TO_EAR;
        if (unitScale < 0.01) return null;

        const midX = (leftEar.position.x + rightEar.position.x) / 2;
        const midY = (leftEar.position.y + rightEar.position.y) / 2;

        const normX = (midX - 0.5) / unitScale;
        const normY = (0.5 - midY) / unitScale;

        const pivotY = normY - HEAD_PROPORTIONS.OFFSET.EAR_Y;

        return {
            center: {
                x: normX * HEAD_PROPORTIONS.WIDTH.EAR_TO_EAR,
                y: pivotY,
                z: (this.config.focalLength * this.config.physicalHeadWidth) / unitScale
            },
            unitScale
        };
    }

    public calculateRollEyes(extracted: RawExtraction): number | null {
        const { left: L, right: R } = extracted.eyes;
        if (!L.isVisible || !R.isVisible) return null;

        return Math.atan2(
            R.position.y - L.position.y,
            R.position.x - L.position.x
        );
    }

    public calculatePitchEyesToEars(extracted: RawExtraction): number | null {
        const { leftEar: leftEar, rightEar: rightEar } = extracted.rig;
        const { left: leftEye, right: rightEye } = extracted.eyes;

        if (!leftEar.isVisible || !rightEar.isVisible || !leftEye.isVisible || !rightEye.isVisible) return null;

        // Normalize first
        const norm = this.normalizeToSkullCenter(extracted);
        if (!norm) return null;

        // In normalized space: leftEar.x ≈ -0.5, rightEar.x ≈ 0.5, leftEye.x ≈ -EYE_TO_EYE/2
        // The vertical gap between eyes and ears is: EYE_LINE + EAR_Y = 0.1 + 0.02 = 0.12
        const anatomicalGap = HEAD_PROPORTIONS.HEIGHT.EYE_LINE + HEAD_PROPORTIONS.OFFSET.EAR_Y;

        const eyeMidY = (norm.leftEye.y + norm.rightEye.y) / 2;
        const earMidY = (norm.leftEar.y + norm.rightEar.y) / 2;

        // Observed gap (should be 0.12 in canonical pose)
        const observedGap = earMidY - eyeMidY;

        // Lever is the depth distance from eyes to ears
        const leverDepth = Math.abs(HEAD_PROPORTIONS.DEPTH.EYE_PLANE);

        // Looking up (nose goes up) -> eyes move down relative to ears -> observedGap increases
        // Looking up should give negative pitch
        return -Math.atan2(observedGap - anatomicalGap, leverDepth);
    }

    public calculateYawNoseToEyes(extracted: RawExtraction): number | null {
        const { left: L, right: R } = extracted.eyes;
        const nose = extracted.nose;

        if (!L.isVisible || !R.isVisible || !nose.isVisible) return null;

        const norm = this.normalizeToSkullCenter(extracted);
        if (!norm) return null;

        // In normalized space after centering at ears:
        // nose.x = sin(yaw) * |NOSE_TIP|
        // So: yaw = asin(nose.x / |NOSE_TIP|)
        const noseTipDepth = Math.abs(HEAD_PROPORTIONS.DEPTH.NOSE_TIP);
        const sinYaw = norm.nose.x / noseTipDepth;
        
        // Clamp to valid range
        const clampedSin = Math.max(-1, Math.min(1, sinYaw));
        
        // nose.x > 0 means looking right = positive yaw
        return Math.asin(clampedSin);
    }

    public calculateYawEarSymmetry(extracted: RawExtraction): number | null {
        const { leftEar: EL, rightEar: ER } = extracted.rig;
        const nose = extracted.nose;

        if (!EL.isVisible || !ER.isVisible || !nose.isVisible) return null;

        const norm = this.normalizeToSkullCenter(extracted);
        if (!norm) return null;

        // After normalization: leftEar.x = -0.5, rightEar.x = +0.5
        // nose.x = sin(yaw) * |NOSE_TIP|
        const noseTipDepth = Math.abs(HEAD_PROPORTIONS.DEPTH.NOSE_TIP);
        const sinYaw = norm.nose.x / noseTipDepth;
        
        const clampedSin = Math.max(-1, Math.min(1, sinYaw));
        
        return Math.asin(clampedSin);
    }

    private validateRotation(pitch: number, yaw: number, roll: number): Vector3 | null {
        if (pitch == null || yaw == null || roll == null) return null;

        const LIMITS = {
            PITCH: Math.PI / 3,
            YAW: Math.PI / 2,
            ROLL: Math.PI / 4
        };

        if (Math.abs(pitch) > LIMITS.PITCH) return null;
        if (Math.abs(yaw) > LIMITS.YAW) return null;
        if (Math.abs(roll) > LIMITS.ROLL) return null;

        return { x: pitch, y: yaw, z: roll };
    }

    public parse(rawLandmarks: any[]): FaceGeometry | null {
        const extracted = FaceParser.extractRawData(rawLandmarks);

        const anchor = this.calculatePositionStrategyEarToEar(extracted);
        if (!anchor) return null;

        const yaw = this.calculateYawEarSymmetry(extracted)
            ?? this.calculateYawNoseToEyes(extracted)
            ?? 0;

        const pitch = this.calculatePitchEyesToEars(extracted)
            ?? 0;

        const roll = this.calculateRollEyes(extracted)
            ?? 0;

        const validatedRotation = this.validateRotation(pitch, yaw, roll);
        if (!validatedRotation) return null;

        const H = HEAD_PROPORTIONS;

        return {
            world: {
                center: anchor.center,
                unitScale: anchor.unitScale,
                rotation: {
                    yaw: validatedRotation.y,
                    pitch: validatedRotation.x,
                    roll: validatedRotation.z
                }
            },
            nose: { x: 0, y: 0, z: H.DEPTH.NOSE_TIP },
            eyes: {
                left: { x: -H.WIDTH.EYE_TO_EYE / 2, y: -H.HEIGHT.EYE_LINE, z: H.DEPTH.EYE_PLANE },
                right: { x: H.WIDTH.EYE_TO_EYE / 2, y: -H.HEIGHT.EYE_LINE, z: H.DEPTH.EYE_PLANE },
                midpoint: { x: 0, y: -H.HEIGHT.EYE_LINE, z: H.DEPTH.EYE_PLANE }
            },
            rig: {
                center: { x: 0, y: 0, z: 0 },
                leftEar: { x: -H.WIDTH.EAR_TO_EAR / 2, y: H.OFFSET.EAR_Y, z: 0 },
                rightEar: { x: H.WIDTH.EAR_TO_EAR / 2, y: H.OFFSET.EAR_Y, z: 0 }
            },
            bounds: {
                left: { x: -H.WIDTH.EAR_TO_EAR / 2, y: 0, z: 0 },
                right: { x: H.WIDTH.EAR_TO_EAR / 2, y: 0, z: 0 },
                top: { x: 0, y: -H.HEIGHT.FOREHEAD_TOP, z: H.DEPTH.EYE_PLANE },
                bottom: { x: 0, y: -H.HEIGHT.CHIN_TIP, z: 0 }
            }
        };
    }
}
